# =============================================================================
# Coinbase WebSocket ETL - Environment Variables
# =============================================================================
# IMPORTANT: Never commit .env to version control.
# Copy this file to .env and fill in your actual values.


# --- AWS Credentials ---
AWS_ACCESS_KEY_ID=your-access-key-id
AWS_SECRET_ACCESS_KEY=your-secret-access-key
AWS_DEFAULT_REGION=ap-southeast-3

# --- S3 Configuration ---
S3_BUCKET_NAME=coinbase-etl-data
S3_RAW_PREFIX=raw/coinbase/ticker
S3_TRANSFORMED_PREFIX=transformed/coinbase/ticker

# --- Redshift / Data Warehouse Configuration ---
REDSHIFT_HOST=your-workgroup.123456789012.region.redshift-serverless.amazonaws.com
REDSHIFT_PORT=5439
REDSHIFT_DB=dev
REDSHIFT_USER=admin
REDSHIFT_PASSWORD=your-redshift-password
REDSHIFT_SCHEMA=public
REDSHIFT_TABLE=ticker_transformed

# --- Streaming Configuration ---
COINBASE_WS_URL=wss://ws-feed.exchange.coinbase.com
COINBASE_PRODUCTS=BTC-USD,ETH-USD,SOL-USD
COINBASE_CHANNELS=ticker
STREAM_DURATION_SECONDS=10
STREAM_BATCH_SIZE=100

# --- Airflow Variables (set automatically via airflow_settings.yaml) ---
AIRFLOW__CORE__LOAD_EXAMPLES=False
